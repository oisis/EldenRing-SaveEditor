{
  "permissions": {
    "allow": [
      "Read(backend/**)",
      "Read(*.go)",

      "Read(frontend/src/**)",
      "Read(frontend/*.{json,js,ts,config.*})",

      "Read(tests/**)",
      "Bash(go test -v ./backend/...)",
      "Bash(go test -v ./tests/roundtrip_test.go)",
      "Bash(go test -v ./tests/steamid_test.go)",
      "Bash(go test -run * ./...)",
      "Bash(make test)",

      "Bash(make build)",
      "Bash(make deps)",
      "Bash(make clean)",
      "Bash(go build ./...)",
      "Bash(go mod tidy)",
      "Bash(go mod download)",

      "Bash(cd frontend && npm install)",
      "Bash(cd frontend && npm run build)",
      "Bash(cd frontend && npm run lint)",
      "Bash(cd frontend && npx tsc --noEmit)",

      "Bash(golangci-lint run ./...)",
      "Bash(gofmt -w *.go)",
      "Bash(gofmt -w backend/**/*.go)",

      "Bash(wails doctor)",
      "Bash(wails version)",

      "Bash(go run scripts/extractor.go *)",

      "Read(scripts/**)"
    ],

    "deny": [
      "Bash(wails dev)",
      "Bash(make dev)",

      "Write(tests/data/**)",
      "Bash(rm -rf build/bin/*)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "bash -c 'FILE=$(echo \\\"$CLAUDE_TOOL_INPUT\\\" | python3 -c \\\"import sys,json; d=json.load(sys.stdin); print(d.get(\\\\\\\"file_path\\\\\\\",d.get(\\\\\\\"path\\\\\\\",\\\\\\\"\\\\\\\")))\\\" 2>/dev/null || echo \\\"\\\"); [[ \\\"$FILE\\\" =~ \\\\.go$ ]] && gofmt -w \\\"$FILE\\\" 2>/dev/null; exit 0'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
