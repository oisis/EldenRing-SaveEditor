# Gemini CLI ignore file

# Build artifacts & Binaries
dist/
build/
bin/
k-view-server
*.exe
*.o
*.so

# Dependencies
node_modules/
vendor/

# Temporary & System files
tmp/
*.log
*.swp
.DS_Store
.AppleDouble
.LSOverride
._*
Icon

# Git & VCS
.git/
.gitignore
.gitattributes

# Secrets & Environment (Crucial!)
.env
.env.*
*.pem
*.key
*.crt
*.pub
kubeconfig
*.p12

# Kubernetes/Helm specific
charts/*/charts/
charts/*/tmp/
.helmignore

# Python (Since you read Python)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/